# Neon PostgreSQL — get this from your Neon dashboard (dev branch)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Auth
AUTH_SECRET="your-secret-here"
# GitHub OAuth
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Resend
RESEND_API_KEY="your-resend-api-key-here"
RESEND_FROM="DevStash <onboarding@resend.dev>"  # use onboarding@resend.dev for dev; set a verified domain in prod
NEXTAUTH_URL="http://localhost:3000"             # used to build verification email links

# Set to false to bypass email verification (useful in dev without a verified Resend domain)
EMAIL_VERIFICATION_ENABLED=true

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL="your-upstash-redis-rest-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"

# ---------------------------------------------------------------------------
# MCP Server keys — set these in your shell profile (~/.zshrc or ~/.zprofile)
# rather than in .env, as they are read by Claude Code at the shell level.
# ---------------------------------------------------------------------------
# NEON_API_KEY="napi_..."        # https://console.neon.tech/app/settings/api-keys
# CONTEXT7_API_KEY="ctx7sk-..."  # https://context7.com
